SPOTIFY_CLIENT_ID="example_spotify_client_id"
SPOTIFY_CLIENT_SECRET="example_spotify_client_secret"
SPOTIFY_REDIRECT_URI="http://localhost:9999/callback"
ENV=development

# Database
DATABASE_URL="postgresql://example_user:example_password@db.example.com:5432/example_database"

# Redis
REDIS_HOST=redis_cache
REDIS_PORT=6379

# RAG service
OPENAI_API_KEY="example_openai_api_key"

# Gemini — generador del chat sobre canciones (rag_service).
# La clave se saca gratis en https://aistudio.google.com/apikey (no pide tarjeta).
# Si la dejas vacía la app arranca igual: el chat responde en modo "solo
# recuperación", mostrando el texto de Wikipedia sin redactar.
GEMINI_API_KEY=""
# Ojo: Google cierra modelos a las cuentas nuevas y los tumba por demanda. Si
# empieza a fallar, cambia este valor por otro de https://aistudio.google.com
GEMINI_MODEL="gemini-flash-lite-latest"

# Chroma
CHROMA_HOST=chroma_db
CHROMA_PORT=8000


SECRET_KEY = "clave-secreta"
ALGORITHM = "algoritmo"
